PORT=3000

# WhatsApp settings
WHATSAPP_ENABLED=true

# Telegram Bot settings
# 1. Talk to @BotFather on Telegram to create a bot and get your token
# 2. Set the token here. If blank, Telegram bot will not start.
TELEGRAM_BOT_TOKEN=

# Optional: You can also configure your Telegram chat ID to allow only certain users
# TELEGRAM_ALLOWED_USERS=123456789,987654321
